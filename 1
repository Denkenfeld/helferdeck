<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Schul-Event Planer (Node UI)</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        /* Karo-Papier Hintergrund */
        .bg-karo {
            background-size: 24px 24px;
            background-image: 
                linear-gradient(to right, rgba(0, 0, 0, 0.04) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(0, 0, 0, 0.04) 1px, transparent 1px);
            background-color: #fcfcf9;
        }

        /* Sanfte Bokeh-Wolken im Hintergrund */
        .bokeh-bg {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            z-index: -1;
            overflow: hidden;
        }
        .bubble {
            position: absolute;
            border-radius: 50%;
            filter: blur(60px);
            opacity: 0.4;
            animation: float 20s infinite alternate ease-in-out;
        }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(50px, 50px) scale(1.2); }
        }

        /* Glassmorphismus */
        .glass-card {
            background: rgba(255, 255, 255, 0.45);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.04);
        }
    </style>
</head>
<body class="bg-karo min-h-screen font-sans text-slate-800 antialiased selection:bg-indigo-100">

    <div class="bokeh-bg pointer-events-none">
        <div class="bubble bg-blue-200 w-96 h-96 top-12 left-[-10%]"></div>
        <div class="bubble bg-amber-100 w-[500px] h-[500px] bottom-10 right-[-10%]" style="animation-delay: -5s;"></div>
        <div class="bubble bg-emerald-100 w-80 h-80 top-1/3 left-1/3" style="animation-delay: -10s;"></div>
    </div>

    <main class="max-w-md mx-auto px-4 py-8 mb-24">
        
        <header class="glass-card rounded-2xl p-6 mb-8 text-center relative overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-indigo-400 via-emerald-400 to-amber-400"></div>
            <span class="text-xs font-mono tracking-widest text-slate-400 uppercase">Veranstaltung</span>
            <h1 class="text-2xl font-bold tracking-tight text-slate-900 mt-1">Großes Schulfest 2026</h1>
            <p class="text-xs text-slate-500 mt-2 flex items-center justify-center gap-1">
                <i data-lucide="calendar" class="w-3.5 h-3.5"></i> Samstag, 12:00 - 16:00 Uhr
            </p>
            
            <div class="mt-4 pt-4 border-t border-white/40">
                <div class="flex justify-between text-xs text-slate-500 mb-1 font-mono">
                    <span>Gesamtbelegung</span>
                    <span id="global-progress-text">0%</span>
                </div>
                <div class="w-full bg-white/50 rounded-full h-1.5 overflow-hidden border border-white/20">
                    <div id="global-progress-bar" class="bg-indigo-500 h-1.5 rounded-full transition-all duration-500" style="width: 0%"></div>
                </div>
            </div>
        </header>

        <div class="relative pl-4" id="node-tree">
            <div class="absolute left-4 top-0 bottom-0 w-[2px] bg-dashed border-l-2 border-dashed border-slate-300 pointer-events-none"></div>
            
            </div>

    </main>

    <div class="fixed bottom-4 right-4 z-50">
        <button onclick="toggleAdminView()" id="admin-btn" class="glass-card px-4 py-2.5 rounded-full text-xs font-mono flex items-center gap-2 hover:bg-white/80 transition-all border border-slate-200 shadow-sm">
            <i data-lucide="shield" class="w-4 h-4 text-indigo-500"></i>
            <span>Admin-Ansicht: Aus</span>
        </button>
    </div>

    <script>
        // Demodaten Struktur (Bereiche -> Aufgaben/Schichten)
        let data = {
            areas: [
                {
                    id: "area-1",
                    title: "Grillstation & Essen",
                    icon: "utensils",
                    image: "https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=150&auto=format&fit=crop&q=60&ixlib=rb-4.0.3",
                    tasks: [
                        { id: "task-1-1", title: "Aufbau Grill (11:00 - 12:00)", req: "Kraft von Vorteil", slots: 2, helpers: [] },
                        { id: "task-1-2", title: "Grillschicht 1 (12:00 - 14:00)", req: "Wurstzange vorhanden", slots: 2, helpers: [{name: "Markus T.", contact: "hidden"}] },
                        { id: "task-1-3", title: "Grillschicht 2 (14:00 - 16:00)", req: "Heiß & fettig", slots: 2, helpers: [] }
                    ]
                },
                {
                    id: "area-2",
                    title: "Kuchen- & Kaffeebuffet",
                    icon: "coffee",
                    image: "https://images.unsplash.com/photo-1509440159596-0249088772ff?w=150&auto=format&fit=crop&q=60&ixlib=rb-4.0.3",
                    tasks: [
                        { id: "task-2-1", title: "Kuchenspende (Obstkuchen)", req: "Bitte beschriften wegen Allergien", slots: 5, helpers: [{name: "Sabine M.", contact: "hidden"}, {name: "Elena K.", contact: "hidden"}] },
                        { id: "task-2-2", title: "Kuchenspende (Trockenkuchen)", req: "Muffins auch okay", slots: 5, helpers: [] },
                        { id: "task-2-3", title: "Verkaufsschicht (12:00 - 14:00)", req: "Wechselgeld-Handling", slots: 2, helpers: [] }
                    ]
                },
                {
                    id: "area-3",
                    title: "Spielstationen (Schulhof)",
                    icon: "dribbble",
                    image: "https://images.unsplash.com/photo-1579684389782-64d84b5e901a?w=150&auto=format&fit=crop&q=60&ixlib=rb-4.0.3",
                    tasks: [
                        { id: "task-3-1", title: "Dosenwerfen Betreuung", req: "Gute Laune mitbringen", slots: 1, helpers: [] },
                        { id: "task-3-2", title: "Sackhüpfen Organisation", req: "Stoppuhr bereitstellen", slots: 1, helpers: [] }
                    ]
                }
            ]
        };

        // Zustandsspeicher
        if (!localStorage.getItem('school_event_data')) {
            localStorage.setItem('school_event_data', JSON.stringify(data));
        } else {
            data = JSON.parse(localStorage.getItem('school_event_data'));
        }

        let isAdmin = false;
        let openForms = {};

        function toggleAdminView() {
            isAdmin = !isAdmin;
            const btn = document.getElementById('admin-btn');
            if (isAdmin) {
                btn.classList.add('bg-indigo-50/80', 'border-indigo-300');
                btn.innerHTML = `<i data-lucide="shield-check" class="w-4 h-4 text-emerald-600"></i> <span>Admin-Ansicht: Ein</span>`;
            } else {
                btn.classList.remove('bg-indigo-50/80', 'border-indigo-300');
                btn.innerHTML = `<i data-lucide="shield" class="w-4 h-4 text-indigo-500"></i> <span>Admin-Ansicht: Aus</span>`;
            }
            lucide.createIcons();
            renderTree();
        }

        function toggleForm(taskId) {
            openForms[taskId] = !openForms[taskId];
            renderTree();
        }

        function handleJoin(event, areaId, taskId) {
            event.preventDefault();
            const nameInput = document.getElementById(`name-${taskId}`).value.trim();
            const contactInput = document.getElementById(`contact-${taskId}`).value.trim();

            if (!nameInput || !contactInput) return;

            // Finde Task und füge Helfer hinzu
            const area = data.areas.find(a => a.id === areaId);
            const task = area.tasks.find(t => t.id === taskId);

            if (task.helpers.length < task.slots) {
                task.helpers.push({ name: nameInput, contact: contactInput });
                localStorage.setItem('school_event_data', JSON.stringify(data));
                openForms[taskId] = false;
                renderTree();
            }
        }

        function handleLeave(areaId, taskId, index) {
            const area = data.areas.find(a => a.id === areaId);
            const task = area.tasks.find(t => t.id === taskId);
            task.helpers.splice(index, 1);
            localStorage.setItem('school_event_data', JSON.stringify(data));
            renderTree();
        }

        function updateGlobalProgress() {
            let totalSlots = 0;
            let filledSlots = 0;
            data.areas.forEach(a => {
                a.tasks.forEach(t => {
                    totalSlots += t.slots;
                    filledSlots += t.helpers.length;
                });
            });
            const percent = totalSlots > 0 ? Math.round((filledSlots / totalSlots) * 100) : 0;
            document.getElementById('global-progress-bar').style.width = `${percent}%`;
            document.getElementById('global-progress-text').innerText = `${percent}% (${filledSlots}/${totalSlots})`;
        }

        function renderTree() {
            const container = document.getElementById('node-tree');
            container.innerHTML = '<div class="absolute left-4 top-0 bottom-0 w-[2px] bg-dashed border-l-2 border-dashed border-slate-300 pointer-events-none"></div>';

            data.areas.forEach((area) => {
                // Berechne Area-Auslastung
                let areaTotal = area.tasks.reduce((acc, t) => acc + t.slots, 0);
                let areaFilled = area.tasks.reduce((acc, t) => acc + t.helpers.length, 0);
                let isAreaFull = areaFilled === areaTotal;

                // Hauptbereich (Unter-Wurzel) Element bauen
                const areaNode = document.createElement('div');
                areaNode.className = "mb-8 relative z-10";
                
                areaNode.innerHTML = `
                    <div class="glass-card rounded-xl p-4 flex items-center gap-3 relative mb-4">
                        <div class="absolute left-0 top-0 bottom-0 w-1 rounded-l-xl ${isAreaFull ? 'bg-emerald-400' : 'bg-amber-400'}"></div>
                        <div class="p-2 bg-white/60 rounded-lg text-slate-600">
                            <i data-lucide="${area.icon || 'folder'}" class="w-5 h-5"></i>
                        </div>
                        <div class="flex-1">
                            <h2 class="text-sm font-bold text-slate-800">${area.title}</h2>
                            <div class="flex items-center gap-2 mt-0.5">
                                <span class="text-[10px] font-mono text-slate-400 uppercase">Bereich</span>
                                <span class="text-[10px] font-mono px-1.5 py-0.2 bg-white/50 border border-slate-200 rounded text-slate-600">${areaFilled}/${areaTotal} Plätze</span>
                            </div>
                        </div>
                        ${area.image ? `<img src="${area.image}" class="w-10 h-10 rounded-lg object-cover border border-white/40" />` : ''}
                    </div>

                    <div class="pl-6 relative space-y-3">
                        <div class="absolute left-2 top-[-16px] bottom-4 w-[2px] border-l-2 border-slate-200 pointer-events-none"></div>
                        
                        ${area.tasks.map(task => {
                            const isFull = task.helpers.length >= task.slots;
                            const isFormOpen = openForms[task.id];

                            return `
                                <div class="relative flex flex-col gap-1">
                                    <div class="absolute left-[-16px] top-5 w-4 h-[2px] bg-slate-200"></div>

                                    <div class="glass-card rounded-xl p-3 transition-all duration-200 hover:border-slate-300">
                                        <div class="flex items-start justify-between gap-2">
                                            <div class="flex-1">
                                                <h3 class="text-xs font-semibold text-slate-700">${task.title}</h3>
                                                <p class="text-[10px] text-slate-400 italic mt-0.5">${task.req}</p>
                                                
                                                <div class="flex flex-wrap gap-1 mt-2">
                                                    ${task.helpers.map((h, idx) => `
                                                        <span class="inline-flex items-center gap-1 bg-emerald-50/80 border border-emerald-200/60 rounded-full px-2 py-0.5 text-[10px] text-emerald-700 font-medium animate-fade-in">
                                                            <span class="w-1 h-1 bg-emerald-500 rounded-full"></span>
                                                            ${h.name}
                                                            ${isAdmin ? `
                                                                <button onclick="handleLeave('${area.id}', '${task.id}', ${idx})" class="hover:text-red-500 ml-0.5 font-bold">×</button>
                                                                <span class="text-[9px] text-slate-400 font-mono">(${h.contact})</span>
                                                            ` : ''}
                                                        </span>
                                                    `).join('')}
                                                    ${Array.from({length: task.slots - task.helpers.length}).map(() => `
                                                        <span class="inline-flex items-center gap-1 bg-white/30 border border-dashed border-slate-300 rounded-full px-2 py-0.5 text-[10px] text-slate-400">
                                                            Frei
                                                        </span>
                                                    `).join('')}
                                                </div>
                                            </div>

                                            ${!isFull ? `
                                                <button onclick="toggleForm('${task.id}')" class="px-2.5 py-1 text-[10px] font-medium rounded-lg transition-all ${isFormOpen ? 'bg-slate-200 text-slate-600' : 'bg-indigo-500 text-white shadow-sm hover:bg-indigo-600'}">
                                                    ${isFormOpen ? 'Schließen' : 'Eintragen'}
                                                </button>
                                            ` : `
                                                <span class="p-1 text-emerald-600"><i data-lucide="check-circle" class="w-4 h-4"></i></span>
                                            `}
                                        </div>

                                        ${isFormOpen ? `
                                            <form onSubmit="handleJoin(event, '${area.id}', '${task.id}')" class="mt-3 pt-3 border-t border-white/40 space-y-2 animate-slide-down">
                                                <div class="grid grid-cols-2 gap-2">
                                                    <input type="text" id="name-${task.id}" required placeholder="Dein Name (z.B. Tim M.)" class="w-full bg-white/80 border border-slate-200 rounded-lg px-2.5 py-1.5 text-xs focus:outline-none focus:ring-2 focus:ring-indigo-400 transition-all" />
                                                    <input type="text" id="contact-${task.id}" required placeholder="Mail oder Tel (Privat)" class="w-full bg-white/80 border border-slate-200 rounded-lg px-2.5 py-1.5 text-xs focus:outline-none focus:ring-2 focus:ring-indigo-400 transition-all" />
                                                </div>
                                                <div class="flex items-center justify-between">
                                                    <p class="text-[9px] text-slate-400 flex items-center gap-1">
                                                        <i data-lucide="lock" class="w-2.5 h-2.5 text-emerald-500"></i> Kontakte sind nur für den Admin sichtbar.
                                                    </p>
                                                    <button type="submit" class="bg-emerald-500 text-white text-[10px] font-medium px-3 py-1.5 rounded-lg hover:bg-emerald-600 shadow-sm transition-all">
                                                        Bestätigen
                                                    </button>
                                                </div>
                                            </form>
                                        ` : ''}
                                    </div>
                                </div>
                            `;
                        }).join('')}
                    </div>
                `;
                container.appendChild(areaNode);
            });

            lucide.createIcons();
            updateGlobalProgress();
        }

        // Initiale Ausführung
        renderTree();
    </script>
</body>
</html>
